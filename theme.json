{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "canvas",
					"color": "#fbf7fb",
					"name": "Ivory Blush"
				},
				{
					"slug": "surface",
					"color": "#f1e7f1",
					"name": "Soft Mauve"
				},
				{
					"slug": "mist",
					"color": "#dcc7d8",
					"name": "Muted Lilac"
				},
				{
					"slug": "blush",
					"color": "#d0a9bd",
					"name": "Dusty Rose"
				},
				{
					"slug": "rosewood",
					"color": "#986c86",
					"name": "Rosewood"
				},
				{
					"slug": "plum",
					"color": "#6e445f",
					"name": "Plum"
				},
				{
					"slug": "ink",
					"color": "#1d131c",
					"name": "Ink"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				}
			],
			"gradients": [
				{
					"slug": "hero-aura",
					"name": "Hero Aura",
					"gradient": "linear-gradient(135deg, #fffafe 0%, #f7eef6 36%, #efdbe9 74%, #e3c5d9 100%)"
				},
				{
					"slug": "soft-radial",
					"name": "Soft Radial",
					"gradient": "radial-gradient(circle at top left, #ffffff 0%, #f6edf5 42%, #f0e5ef 100%)"
				}
			]
		},
		"custom": {
			"radius": {
				"soft": "36px",
				"pill": "999px"
			},
			"spacing": {
				"content": "min(1240px, calc(100vw - 48px))",
				"wide": "min(1400px, calc(100vw - 48px))"
			}
		},
		"layout": {
			"contentSize": "840px",
			"wideSize": "1260px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Soft",
					"slug": "soft",
					"shadow": "0 26px 60px rgba(69, 32, 59, 0.10)"
				},
				{
					"name": "Lifted",
					"slug": "lifted",
					"shadow": "0 36px 100px rgba(62, 29, 54, 0.16)"
				}
			]
		},
		"spacing": {
			"blockGap": "1.5rem",
			"margin": true,
			"padding": true,
			"spacingSizes": [
				{
					"slug": "2xs",
					"size": "0.5rem",
					"name": "2XS"
				},
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "1.25rem",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "2rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "4.5rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "6.5rem",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "9rem",
					"name": "2XL"
				}
			],
			"units": [
				"px",
				"rem",
				"em",
				"vw",
				"%"
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Cormorant Garamond\", Georgia, serif",
					"name": "Cormorant Garamond",
					"slug": "display"
				},
				{
					"fontFamily": "\"Manrope\", \"Segoe UI\", sans-serif",
					"name": "Manrope",
					"slug": "body"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "1rem",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "1.125rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "1.5rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "clamp(3.2rem, 5vw, 5.2rem)",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "clamp(4.4rem, 8vw, 7.2rem)",
					"name": "2XL"
				}
			],
			"lineHeight": true
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "999px"
				},
				"spacing": {
					"padding": {
						"top": "1rem",
						"right": "1.8rem",
						"bottom": "1rem",
						"left": "1.8rem"
					}
				},
				"typography": {
					"fontSize": "0.95rem",
					"fontWeight": "700",
					"letterSpacing": "0.03em"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "0.95rem",
					"fontWeight": "600"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)"
				}
			}
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--canvas)",
			"text": "var(--wp--preset--color--ink)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--plum)",
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "0.9"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "0.94"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--plum)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--ink)"
					}
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"right": "24px",
				"left": "24px"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1rem",
			"fontWeight": "400",
			"lineHeight": "1.78"
		},
		"blocks": {
			"core/buttons": {
				"spacing": {
					"blockGap": "0.95rem"
				}
			},
			"core/image": {
				"border": {
					"radius": "36px"
				}
			},
			"core/navigation-link": {
				"typography": {
					"textDecoration": "none"
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "36px"
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--mist)"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Ust Bilgi"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Alt Bilgi"
		}
	]
}
