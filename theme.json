{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "canvas",
					"color": "#faf3f5",
					"name": "Warm Canvas"
				},
				{
					"slug": "surface",
					"color": "#fff9fa",
					"name": "Soft Surface"
				},
				{
					"slug": "blush",
					"color": "#f6ecef",
					"name": "Warm Blush"
				},
				{
					"slug": "lilac",
					"color": "#ead6de",
					"name": "Muted Lilac"
				},
				{
					"slug": "mist",
					"color": "#d8d0d9",
					"name": "Soft Mist"
				},
				{
					"slug": "rose",
					"color": "#b98398",
					"name": "Dusty Rose"
				},
				{
					"slug": "apricot",
					"color": "#d7b2c1",
					"name": "Apricot Accent"
				},
				{
					"slug": "champagne",
					"color": "#f2dcc4",
					"name": "Champagne"
				},
				{
					"slug": "mauve",
					"color": "#8c5a72",
					"name": "Muted Mauve"
				},
				{
					"slug": "plum",
					"color": "#6b3d53",
					"name": "Deep Plum"
				},
				{
					"slug": "night",
					"color": "#2d1b27",
					"name": "Night Plum"
				},
				{
					"slug": "ink",
					"color": "#2d2330",
					"name": "Ink"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				}
			],
			"gradients": [
				{
					"slug": "hero-glow",
					"name": "Hero Glow",
					"gradient": "linear-gradient(135deg, #fff9fa 0%, #f6ecef 32%, #f1e1e7 68%, #ead6de 100%)"
				},
				{
					"slug": "soft-panel",
					"name": "Soft Panel",
					"gradient": "linear-gradient(180deg, #fff9fa 0%, #f6ecef 100%)"
				},
				{
					"slug": "soft-radial",
					"name": "Soft Radial",
					"gradient": "radial-gradient(circle at top left, #fffaf6 0%, #f5ede7 44%, #eadedf 100%)"
				},
				{
					"slug": "deep-panel",
					"name": "Deep Panel",
					"gradient": "linear-gradient(135deg, #2d1724 0%, #4d243f 54%, #85586c 100%)"
				}
			]
		},
		"custom": {
			"radius": {
				"card": "28px",
				"soft": "34px",
				"pill": "999px"
			},
			"spacing": {
					"content": "min(1420px, calc(100vw - 44px))",
					"wide": "min(1720px, calc(100vw - 44px))"
			}
		},
		"layout": {
			"contentSize": "1040px",
			"wideSize": "1560px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Soft",
					"slug": "soft",
					"shadow": "0 20px 44px rgba(58, 27, 46, 0.08)"
				},
				{
					"name": "Lifted",
					"slug": "lifted",
					"shadow": "0 30px 70px rgba(49, 21, 39, 0.14)"
				},
				{
					"name": "Dramatic",
					"slug": "dramatic",
					"shadow": "0 36px 100px rgba(33, 20, 29, 0.24)"
				}
			]
		},
		"spacing": {
			"blockGap": "1.35rem",
			"margin": true,
			"padding": true,
			"spacingSizes": [
				{
					"slug": "2xs",
					"size": "0.5rem",
					"name": "2XS"
				},
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "1.25rem",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "2rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "4rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "5.75rem",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "7.5rem",
					"name": "2XL"
				}
			],
			"units": [
				"px",
				"rem",
				"em",
				"vw",
				"%"
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Cormorant Garamond\", Georgia, serif",
					"name": "Cormorant Garamond",
					"slug": "display"
				},
				{
					"fontFamily": "\"Manrope\", \"Segoe UI\", sans-serif",
					"name": "Manrope",
					"slug": "body"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "1rem",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "1.125rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "1.25rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "clamp(2.1rem, 2.5vw, 3rem)",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "clamp(3.25rem, 4.3vw, 4.25rem)",
					"name": "2XL"
				}
			],
			"lineHeight": true
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "999px"
				},
				"spacing": {
					"padding": {
						"top": "0.95rem",
						"right": "1.55rem",
						"bottom": "0.95rem",
						"left": "1.55rem"
					}
				},
				"typography": {
					"fontSize": "0.93rem",
					"fontWeight": "700",
					"letterSpacing": "0.03em"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "0.94rem",
					"fontWeight": "600",
					"letterSpacing": "0.02em"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)"
				}
			}
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--canvas)",
			"text": "var(--wp--preset--color--ink)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--plum)",
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "0.97"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "1.02"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "1.08"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--plum)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--rose)"
					}
				}
			}
		},
		"spacing": {
			"blockGap": "1.35rem",
			"padding": {
				"left": "20px",
				"right": "20px"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1rem",
			"fontWeight": "400",
			"lineHeight": "1.68"
		},
		"blocks": {
			"core/buttons": {
				"spacing": {
					"blockGap": "0.9rem"
				}
			},
			"core/image": {
				"border": {
					"radius": "28px"
				}
			},
			"core/navigation-link": {
				"typography": {
					"textDecoration": "none"
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "28px"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Ust Bilgi"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Alt Bilgi"
		}
	]
}
