{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "canvas",
					"color": "#fdf8fc",
					"name": "Blush Ivory"
				},
				{
					"slug": "surface",
					"color": "#f5ebf4",
					"name": "Petal Veil"
				},
				{
					"slug": "mist",
					"color": "#ddcbdb",
					"name": "Muted Lilac"
				},
				{
					"slug": "blush",
					"color": "#d6abbd",
					"name": "Dusty Rose"
				},
				{
					"slug": "mauve",
					"color": "#b889a4",
					"name": "Soft Mauve"
				},
				{
					"slug": "plum",
					"color": "#5c314e",
					"name": "Deep Plum"
				},
				{
					"slug": "ink",
					"color": "#1f1620",
					"name": "Ink"
				},
				{
					"slug": "champagne",
					"color": "#efd9c8",
					"name": "Champagne"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				}
			],
			"gradients": [
				{
					"slug": "hero-aura",
					"name": "Hero Aura",
					"gradient": "linear-gradient(135deg, #fffafc 0%, #f7edf5 32%, #ecd9e7 68%, #e0c1d4 100%)"
				},
				{
					"slug": "soft-radial",
					"name": "Soft Radial",
					"gradient": "radial-gradient(circle at top left, #ffffff 0%, #f7eef5 42%, #f0e4ee 100%)"
				},
				{
					"slug": "editorial-haze",
					"name": "Editorial Haze",
					"gradient": "linear-gradient(145deg, #1f1620 0%, #4a2940 40%, #714961 100%)"
				}
			]
		},
		"custom": {
			"radius": {
				"soft": "34px",
				"card": "28px",
				"pill": "999px"
			},
			"spacing": {
				"content": "min(1320px, calc(100vw - 48px))",
				"wide": "min(1540px, calc(100vw - 48px))"
			}
		},
		"layout": {
			"contentSize": "920px",
			"wideSize": "1380px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Soft",
					"slug": "soft",
					"shadow": "0 26px 60px rgba(55, 25, 47, 0.10)"
				},
				{
					"name": "Lifted",
					"slug": "lifted",
					"shadow": "0 38px 96px rgba(46, 20, 41, 0.16)"
				},
				{
					"name": "Dramatic",
					"slug": "dramatic",
					"shadow": "0 50px 140px rgba(40, 17, 36, 0.22)"
				}
			]
		},
		"spacing": {
			"blockGap": "1.5rem",
			"margin": true,
			"padding": true,
			"spacingSizes": [
				{
					"slug": "2xs",
					"size": "0.5rem",
					"name": "2XS"
				},
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "1.25rem",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "2rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "4.5rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "7rem",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "9.75rem",
					"name": "2XL"
				}
			],
			"units": [
				"px",
				"rem",
				"em",
				"vw",
				"%"
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Cormorant Garamond\", Georgia, serif",
					"name": "Cormorant Garamond",
					"slug": "display"
				},
				{
					"fontFamily": "\"Manrope\", \"Segoe UI\", sans-serif",
					"name": "Manrope",
					"slug": "body"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "1rem",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "1.125rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "1.375rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "clamp(2.2rem, 2.8vw, 2.75rem)",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "clamp(3.5rem, 4.8vw, 4.25rem)",
					"name": "2XL"
				}
			],
			"lineHeight": true
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "999px"
				},
				"spacing": {
					"padding": {
						"top": "0.95rem",
						"right": "1.55rem",
						"bottom": "0.95rem",
						"left": "1.55rem"
					}
				},
				"typography": {
					"fontSize": "0.92rem",
					"fontWeight": "700",
					"letterSpacing": "0.04em"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "0.95rem",
					"fontWeight": "600",
					"letterSpacing": "0.03em"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)"
				}
			}
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--canvas)",
			"text": "var(--wp--preset--color--ink)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--plum)",
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "0.94"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "0.98"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--plum)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--ink)"
					}
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"right": "24px",
				"left": "24px"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1rem",
			"fontWeight": "400",
			"lineHeight": "1.72"
		},
		"blocks": {
			"core/buttons": {
				"spacing": {
					"blockGap": "1rem"
				}
			},
			"core/image": {
				"border": {
					"radius": "34px"
				}
			},
			"core/navigation-link": {
				"typography": {
					"textDecoration": "none"
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "30px"
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--mist)"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Ust Bilgi"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Alt Bilgi"
		}
	]
}
