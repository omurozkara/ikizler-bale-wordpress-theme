{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "canvas",
					"color": "#f8f3f7",
					"name": "Kirik Beyaz"
				},
				{
					"slug": "surface",
					"color": "#efe5ef",
					"name": "Lila Sis"
				},
				{
					"slug": "mist",
					"color": "#dcc8dd",
					"name": "Pembe Lila"
				},
				{
					"slug": "blush",
					"color": "#cba6bd",
					"name": "Pudra Gul"
				},
				{
					"slug": "plum",
					"color": "#7b4f6d",
					"name": "Murdum"
				},
				{
					"slug": "rosewood",
					"color": "#9b6e87",
					"name": "Gul Agaci"
				},
				{
					"slug": "ink",
					"color": "#20141f",
					"name": "Gece Eflatun"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "Beyaz"
				}
			],
			"gradients": [
				{
					"slug": "hero-aura",
					"name": "Hero Aura",
					"gradient": "linear-gradient(135deg, #fbf7fb 0%, #f2e9f2 36%, #ebd7e4 74%, #d7bfd3 100%)"
				},
				{
					"slug": "soft-radial",
					"name": "Soft Radial",
					"gradient": "radial-gradient(circle at top left, #ffffff 0%, #f4ebf5 40%, #efe5ef 100%)"
				}
			]
		},
		"custom": {
			"radius": {
				"soft": "34px",
				"pill": "999px"
			},
			"spacing": {
				"content": "min(1220px, calc(100vw - 40px))",
				"wide": "min(1380px, calc(100vw - 40px))"
			}
		},
		"layout": {
			"contentSize": "820px",
			"wideSize": "1240px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Soft",
					"slug": "soft",
					"shadow": "0 24px 60px rgba(56, 28, 52, 0.10)"
				},
				{
					"name": "Lifted",
					"slug": "lifted",
					"shadow": "0 34px 90px rgba(47, 22, 44, 0.16)"
				}
			]
		},
		"spacing": {
			"blockGap": "1.5rem",
			"margin": true,
			"padding": true,
			"spacingSizes": [
				{
					"slug": "2xs",
					"size": "0.5rem",
					"name": "2XS"
				},
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "1.25rem",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "2rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "4rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "6rem",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "8.5rem",
					"name": "2XL"
				}
			],
			"units": [
				"px",
				"rem",
				"em",
				"vw",
				"%"
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Cormorant Garamond\", Georgia, serif",
					"name": "Cormorant Garamond",
					"slug": "display"
				},
				{
					"fontFamily": "\"Manrope\", \"Segoe UI\", sans-serif",
					"name": "Manrope",
					"slug": "body"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "1rem",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "1.125rem",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "1.45rem",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "clamp(2.9rem, 5vw, 4.9rem)",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "clamp(4rem, 8vw, 6.9rem)",
					"name": "2XL"
				}
			],
			"lineHeight": true
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "999px"
				},
				"spacing": {
					"padding": {
						"top": "1rem",
						"right": "1.65rem",
						"bottom": "1rem",
						"left": "1.65rem"
					}
				},
				"typography": {
					"fontSize": "0.95rem",
					"fontWeight": "700",
					"letterSpacing": "0.02em"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "0.95rem",
					"fontWeight": "600"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "1.55rem",
					"fontWeight": "600",
					"letterSpacing": "0.02em"
				}
			}
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--canvas)",
			"text": "var(--wp--preset--color--ink)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--plum)",
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "0.92"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"lineHeight": "0.96"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--plum)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--ink)"
					}
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"right": "20px",
				"left": "20px"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1rem",
			"fontWeight": "400",
			"lineHeight": "1.75"
		},
		"blocks": {
			"core/buttons": {
				"spacing": {
					"blockGap": "0.95rem"
				}
			},
			"core/group": {
				"spacing": {
					"blockGap": "1.5rem"
				}
			},
			"core/image": {
				"border": {
					"radius": "34px"
				}
			},
			"core/navigation-link": {
				"typography": {
					"textDecoration": "none"
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "34px"
				}
			},
			"core/query-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)"
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--mist)"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Ust Bilgi"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Alt Bilgi"
		}
	]
}
